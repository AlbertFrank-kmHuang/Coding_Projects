#include <SFML/Graphics.hpp>
#include <cmath>
#include <iostream>
#include <vector>

// 窗口大小
const int WINDOW_WIDTH = 800;
const int WINDOW_HEIGHT = 600;

const int ARENA_LEFT   = 50;
const int ARENA_RIGHT  = WINDOW_WIDTH - 50;
const int ARENA_TOP    = 50;
const int ARENA_BOTTOM = WINDOW_HEIGHT - 50;

const float PLAYER_RADIUS = 20.f;
const float ENEMY_RADIUS  = 20.f;
const float SPEED = 200.f;
const float ATTACK_RADIUS = PLAYER_RADIUS + 40.f;
const float ATTACK_CD = 0.8f;
const float DEFENSE_CD = 1.0f;

// 击退参数（提高）
const float KNOCKBACK_DISTANCE = 50.f;   // 从30增加到50
const float KNOCKBACK_DURATION = 0.15f;

// 护盾破碎特效参数
const float SHATTER_DURATION = 0.3f;

// 血量初始值
const int START_HP = 10;

// ---------- 辅助函数 ----------
float distance(sf::Vector2f a, sf::Vector2f b) {
    return std::sqrt((a.x - b.x)*(a.x - b.x) + (a.y - b.y)*(a.y - b.y));
}

float clamp(float value, float minVal, float maxVal) {
    return std::max(minVal, std::min(value, maxVal));
}

bool sectorIntersectsCircle(sf::Vector2f center, float angle, float radius,
                            sf::Vector2f circleCenter, float circleRadius) {
    float halfAngle = 60.f * M_PI / 180.f;
    float startAngle = angle - halfAngle;
    float endAngle = angle + halfAngle;

    sf::Vector2f toCircle = circleCenter - center;
    float distToCenter = std::sqrt(toCircle.x * toCircle.x + toCircle.y * toCircle.y);
    if (distToCenter > radius + circleRadius) return false;

    float circleAngle = std::atan2(toCircle.y, toCircle.x);
    float angleDiff = circleAngle - angle;
    while (angleDiff > M_PI) angleDiff -= 2 * M_PI;
    while (angleDiff < -M_PI) angleDiff += 2 * M_PI;
    if (std::abs(angleDiff) <= halfAngle) return true;

    sf::Vector2f dir1(std::cos(startAngle), std::sin(startAngle));
    sf::Vector2f dir2(std::cos(endAngle), std::sin(endAngle));
    float cross1 = std::abs(dir1.x * toCircle.y - dir1.y * toCircle.x);
    if (cross1 <= circleRadius && (toCircle.x * dir1.x + toCircle.y * dir1.y) >= 0) return true;
    float cross2 = std::abs(dir2.x * toCircle.y - dir2.y * toCircle.x);
    if (cross2 <= circleRadius && (toCircle.x * dir2.x + toCircle.y * dir2.y) >= 0) return true;
    if (distToCenter > radius - circleRadius && distToCenter < radius + circleRadius) return true;
    return false;
}

void drawCooldownCircle(sf::RenderWindow& window, sf::Vector2f center, float radius,
                        float currentCD, float totalCD) {
    if (currentCD <= 0.f) return;
    float progress = currentCD / totalCD;
    float angleFilled = (1.f - progress) * 360.f;
    if (angleFilled <= 0.f) return;

    sf::ConvexShape sector;
    int pointCount = 30;
    sector.setPointCount(pointCount + 2);
    float startDeg = -90.f;
    float endDeg = startDeg + angleFilled;
    float startRad = startDeg * M_PI / 180.f;
    float endRad   = endDeg   * M_PI / 180.f;
    sector.setPoint(0, center);
    for (int i = 0; i <= pointCount; ++i) {
        float t = (float)i / pointCount;
        float rad = startRad + t * (endRad - startRad);
        sf::Vector2f offset(radius * std::cos(rad), radius * std::sin(rad));
        sector.setPoint(i+1, center + offset);
    }
    sector.setFillColor(sf::Color(128, 128, 128, 180));
    window.draw(sector);
}

// 破碎特效结构
struct ShatterEffect {
    sf::Vector2f center;
    float radius;
    float maxRadius;
    float lifetime;    // 剩余时间
    sf::Color color;

    ShatterEffect(sf::Vector2f c, float startR, float endR, float duration)
        : center(c), radius(startR), maxRadius(endR), lifetime(duration) {
        color = sf::Color(0, 200, 255, 180);
    }

    bool update(float dt) {
        lifetime -= dt;
        if (lifetime <= 0.f) return false;
        float t = 1.f - (lifetime / SHATTER_DURATION);  // 0→1
        radius = maxRadius * t;  // 线性扩大
        color.a = 180 * (1.f - t);  // 淡出
        return true;
    }

    void draw(sf::RenderWindow& window) {
        sf::CircleShape circle(radius);
        circle.setOrigin(radius, radius);
        circle.setPosition(center);
        circle.setFillColor(sf::Color::Transparent);
        circle.setOutlineColor(color);
        circle.setOutlineThickness(3.f);
        window.draw(circle);
    }
};

struct Character {
    sf::Vector2f pos;
    sf::CircleShape body;
    sf::Color originalColor;
    sf::Color currentColor;
    float radius;
    int hp;

    float attackRemaining;
    bool showAttackSector;
    sf::Clock attackSectorTimer;
    bool attackHitEffect;
    sf::Clock hitEffectTimer;

    bool shieldActive;
    float defenseRemaining;

    sf::Vector2f knockbackVelocity;
    float knockbackTimer;

    Character(sf::Vector2f startPos, sf::Color col, float r)
        : pos(startPos), originalColor(col), currentColor(col), radius(r), hp(START_HP),
          attackRemaining(0.f), showAttackSector(false), attackHitEffect(false),
          shieldActive(false), defenseRemaining(0.f),
          knockbackVelocity(0.f,0.f), knockbackTimer(0.f) {
        body.setRadius(radius);
        body.setOrigin(radius, radius);
        body.setFillColor(currentColor);
    }

    void update(float deltaTime) {
        if (attackRemaining > 0) attackRemaining -= deltaTime;
        if (defenseRemaining > 0) defenseRemaining -= deltaTime;

        if (showAttackSector && attackSectorTimer.getElapsedTime().asSeconds() > 0.15f)
            showAttackSector = false;

        if (attackHitEffect && hitEffectTimer.getElapsedTime().asSeconds() > 0.2f) {
            attackHitEffect = false;
            currentColor = originalColor;
            body.setFillColor(currentColor);
        }

        if (knockbackTimer > 0.f) {
            pos += knockbackVelocity * deltaTime;
            knockbackTimer -= deltaTime;
            if (knockbackTimer <= 0.f)
                knockbackVelocity = sf::Vector2f(0.f, 0.f);
        }
    }

    void applyKnockback(sf::Vector2f attackerPos, float duration, float distance) {
        sf::Vector2f dir = pos - attackerPos;
        float len = std::sqrt(dir.x*dir.x + dir.y*dir.y);
        if (len > 0.001f) dir /= len;
        else dir = sf::Vector2f(1.f, 0.f);
        knockbackVelocity = dir * (distance / duration);
        knockbackTimer = duration;
    }

    void draw(sf::RenderWindow& window) {
        body.setPosition(pos);
        window.draw(body);
        drawCooldownCircle(window, pos, 10.f, (attackRemaining>0?attackRemaining:0.f), ATTACK_CD);
        if (shieldActive) {
            sf::CircleShape shield(radius + 8.f);
            shield.setOrigin(radius + 8.f, radius + 8.f);
            shield.setPosition(pos);
            shield.setFillColor(sf::Color::Transparent);
            shield.setOutlineColor(sf::Color(0, 200, 255, 180));
            shield.setOutlineThickness(3.f);
            window.draw(shield);
        }
    }

    void takeDamage(Character& attacker, bool& hitEffectFlag) {
        hp--;
        applyKnockback(attacker.pos, KNOCKBACK_DURATION, KNOCKBACK_DISTANCE);
        currentColor = sf::Color::White;
        body.setFillColor(currentColor);
        attackHitEffect = true;
        hitEffectTimer.restart();
    }

    // 破盾，并返回是否需要击退攻击者（由调用方处理）
    void breakShield(Character& attacker, std::vector<ShatterEffect>& effects) {
        if (!shieldActive) return;
        shieldActive = false;
        defenseRemaining = DEFENSE_CD;
        // 护盾破碎特效：从护盾半径开始扩散到半径的1.8倍
        float startR = radius + 8.f;
        float endR = startR * 1.8f;
        effects.emplace_back(pos, startR, endR, SHATTER_DURATION);
        // 击退攻击者（方向从被破盾者指向攻击者）
        attacker.applyKnockback(pos, KNOCKBACK_DURATION, KNOCKBACK_DISTANCE);
        std::cout << "Shield broken and knockback applied to attacker!" << std::endl;
    }
};

void handleCollision(Character& a, Character& b) {
    sf::Vector2f delta = a.pos - b.pos;
    float dist = std::sqrt(delta.x*delta.x + delta.y*delta.y);
    float minDist = a.radius + b.radius;
    if (dist < minDist) {
        float overlap = minDist - dist;
        sf::Vector2f dir = delta;
        if (dist > 0.001f) dir /= dist;
        else dir = sf::Vector2f(1.f, 0.f);
        sf::Vector2f correction = dir * (overlap / 2.f);
        a.pos += correction;
        b.pos -= correction;
        a.pos.x = clamp(a.pos.x, ARENA_LEFT + a.radius, ARENA_RIGHT - a.radius);
        a.pos.y = clamp(a.pos.y, ARENA_TOP + a.radius, ARENA_BOTTOM - a.radius);
        b.pos.x = clamp(b.pos.x, ARENA_LEFT + b.radius, ARENA_RIGHT - b.radius);
        b.pos.y = clamp(b.pos.y, ARENA_TOP + b.radius, ARENA_BOTTOM - b.radius);
    }
}

int main() {
    sf::RenderWindow window(sf::VideoMode(WINDOW_WIDTH, WINDOW_HEIGHT), "Double Fight");
    window.setFramerateLimit(60);

    Character red(sf::Vector2f(400.f, 300.f), sf::Color::Red, PLAYER_RADIUS);
    Character blue(sf::Vector2f(600.f, 300.f), sf::Color::Blue, ENEMY_RADIUS);

    std::vector<ShatterEffect> shatterEffects;

    sf::Font font;
    bool fontLoaded = false;
    if (font.loadFromFile("/System/Library/Fonts/Helvetica.ttc"))
        fontLoaded = true;
    else if (font.loadFromFile("/System/Library/Fonts/Arial.ttf"))
        fontLoaded = true;

    sf::Text hpText, winText;
    if (fontLoaded) {
        hpText.setFont(font);
        winText.setFont(font);
    }
    hpText.setCharacterSize(20);
    winText.setCharacterSize(30);
    hpText.setFillColor(sf::Color::White);
    winText.setFillColor(sf::Color::Green);
    hpText.setPosition(10, 10);
    winText.setString("VICTORY! Press ESC");

    bool redSpacePressed = false;
    bool blueNPressed = false;

    while (window.isOpen()) {
        sf::Event event;
        while (window.pollEvent(event)) {
            if (event.type == sf::Event::Closed)
                window.close();
        }

        float deltaTime = 1.f / 60.f;

        if (red.hp > 0 && blue.hp > 0) {
            // 移动
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::W)) red.pos.y -= SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::S)) red.pos.y += SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::A)) red.pos.x -= SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::D)) red.pos.x += SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Up))    blue.pos.y -= SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Down))  blue.pos.y += SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Left))  blue.pos.x -= SPEED * deltaTime;
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Right)) blue.pos.x += SPEED * deltaTime;
        }
        red.pos.x = clamp(red.pos.x, ARENA_LEFT + red.radius, ARENA_RIGHT - red.radius);
        red.pos.y = clamp(red.pos.y, ARENA_TOP + red.radius, ARENA_BOTTOM - red.radius);
        blue.pos.x = clamp(blue.pos.x, ARENA_LEFT + blue.radius, ARENA_RIGHT - blue.radius);
        blue.pos.y = clamp(blue.pos.y, ARENA_TOP + blue.radius, ARENA_BOTTOM - blue.radius);

        // 防御逻辑
        bool redShift = sf::Keyboard::isKeyPressed(sf::Keyboard::LShift);
        if (redShift && red.defenseRemaining <= 0.f && red.hp > 0 && blue.hp > 0)
            red.shieldActive = true;
        else if (!redShift)
            red.shieldActive = false;

        bool blueM = sf::Keyboard::isKeyPressed(sf::Keyboard::M);
        if (blueM && blue.defenseRemaining <= 0.f && blue.hp > 0 && red.hp > 0)
            blue.shieldActive = true;
        else if (!blueM)
            blue.shieldActive = false;

        // ------------------- 红球攻击 -------------------
        bool redSpaceNow = sf::Keyboard::isKeyPressed(sf::Keyboard::Space);
        if (redSpaceNow && !redSpacePressed && red.attackRemaining <= 0.f && red.hp > 0 && blue.hp > 0 && !red.shieldActive) {
            red.attackRemaining = ATTACK_CD;
            red.showAttackSector = true;
            red.attackSectorTimer.restart();

            float angle = std::atan2(blue.pos.y - red.pos.y, blue.pos.x - red.pos.x);
            float shieldRadius = blue.radius + 8.f;

            bool hitShield = sectorIntersectsCircle(red.pos, angle, ATTACK_RADIUS, blue.pos, shieldRadius);
            if (hitShield && blue.shieldActive) {
                blue.breakShield(red, shatterEffects);
            } else {
                bool hitBody = sectorIntersectsCircle(red.pos, angle, ATTACK_RADIUS, blue.pos, blue.radius);
                if (hitBody) {
                    blue.takeDamage(red, blue.attackHitEffect);
                    std::cout << "Red hit Blue! Blue HP: " << blue.hp << std::endl;
                } else {
                    std::cout << "Red missed!" << std::endl;
                }
            }
        }
        redSpacePressed = redSpaceNow;

        // ------------------- 蓝球攻击 -------------------
        bool blueNNow = sf::Keyboard::isKeyPressed(sf::Keyboard::N);
        if (blueNNow && !blueNPressed && blue.attackRemaining <= 0.f && blue.hp > 0 && red.hp > 0 && !blue.shieldActive) {
            blue.attackRemaining = ATTACK_CD;
            blue.showAttackSector = true;
            blue.attackSectorTimer.restart();

            float angle = std::atan2(red.pos.y - blue.pos.y, red.pos.x - blue.pos.x);
            float shieldRadius = red.radius + 8.f;

            bool hitShield = sectorIntersectsCircle(blue.pos, angle, ATTACK_RADIUS, red.pos, shieldRadius);
            if (hitShield && red.shieldActive) {
                red.breakShield(blue, shatterEffects);
            } else {
                bool hitBody = sectorIntersectsCircle(blue.pos, angle, ATTACK_RADIUS, red.pos, red.radius);
                if (hitBody) {
                    red.takeDamage(blue, red.attackHitEffect);
                    std::cout << "Blue hit Red! Red HP: " << red.hp << std::endl;
                } else {
                    std::cout << "Blue missed!" << std::endl;
                }
            }
        }
        blueNPressed = blueNNow;

        red.update(deltaTime);
        blue.update(deltaTime);
        handleCollision(red, blue);

        // 更新破碎特效
        for (auto it = shatterEffects.begin(); it != shatterEffects.end(); ) {
            if (!it->update(deltaTime))
                it = shatterEffects.erase(it);
            else
                ++it;
        }

        // 绘图
        window.clear(sf::Color::Black);

        sf::RectangleShape arenaBorder(sf::Vector2f(ARENA_RIGHT - ARENA_LEFT, ARENA_BOTTOM - ARENA_TOP));
        arenaBorder.setPosition(ARENA_LEFT, ARENA_TOP);
        arenaBorder.setFillColor(sf::Color::Transparent);
        arenaBorder.setOutlineColor(sf::Color::White);
        arenaBorder.setOutlineThickness(2.f);
        window.draw(arenaBorder);

        float redAngle = std::atan2(blue.pos.y - red.pos.y, blue.pos.x - red.pos.x);
        float blueAngle = std::atan2(red.pos.y - blue.pos.y, red.pos.x - blue.pos.x);

        // 红刀
        sf::Vector2f redKnifeTip = red.pos + sf::Vector2f(std::cos(redAngle), std::sin(redAngle)) * (red.radius + 10.f);
        sf::VertexArray redTriangle(sf::Triangles, 3);
        redTriangle[0].position = redKnifeTip;
        sf::Vector2f side1 = sf::Vector2f(-std::sin(redAngle), std::cos(redAngle)) * 8.f;
        redTriangle[1].position = redKnifeTip + side1;
        redTriangle[2].position = redKnifeTip - side1;
        redTriangle[0].color = sf::Color::Yellow;
        redTriangle[1].color = sf::Color::Yellow;
        redTriangle[2].color = sf::Color::Yellow;
        window.draw(redTriangle);

        // 蓝刀
        sf::Vector2f blueKnifeTip = blue.pos + sf::Vector2f(std::cos(blueAngle), std::sin(blueAngle)) * (blue.radius + 10.f);
        sf::VertexArray blueTriangle(sf::Triangles, 3);
        blueTriangle[0].position = blueKnifeTip;
        sf::Vector2f side2 = sf::Vector2f(-std::sin(blueAngle), std::cos(blueAngle)) * 8.f;
        blueTriangle[1].position = blueKnifeTip + side2;
        blueTriangle[2].position = blueKnifeTip - side2;
        blueTriangle[0].color = sf::Color::Yellow;
        blueTriangle[1].color = sf::Color::Yellow;
        blueTriangle[2].color = sf::Color::Yellow;
        window.draw(blueTriangle);

        // 攻击扇形
        if (red.showAttackSector) {
            sf::ConvexShape sector;
            sector.setPointCount(32);
            float startAng = redAngle - 60.f * M_PI / 180.f;
            float endAng   = redAngle + 60.f * M_PI / 180.f;
            sector.setPoint(0, red.pos);
            for (int i = 0; i <= 30; ++i) {
                float t = (float)i / 30.f;
                float theta = startAng + t * (endAng - startAng);
                sf::Vector2f offset(ATTACK_RADIUS * std::cos(theta), ATTACK_RADIUS * std::sin(theta));
                sector.setPoint(i+1, red.pos + offset);
            }
            sector.setFillColor(sf::Color(255, 255, 0, 150));
            window.draw(sector);
        }
        if (blue.showAttackSector) {
            sf::ConvexShape sector;
            sector.setPointCount(32);
            float startAng = blueAngle - 60.f * M_PI / 180.f;
            float endAng   = blueAngle + 60.f * M_PI / 180.f;
            sector.setPoint(0, blue.pos);
            for (int i = 0; i <= 30; ++i) {
                float t = (float)i / 30.f;
                float theta = startAng + t * (endAng - startAng);
                sf::Vector2f offset(ATTACK_RADIUS * std::cos(theta), ATTACK_RADIUS * std::sin(theta));
                sector.setPoint(i+1, blue.pos + offset);
            }
            sector.setFillColor(sf::Color(255, 255, 0, 150));
            window.draw(sector);
        }

        red.draw(window);
        blue.draw(window);

        // 绘制破碎特效
        for (auto& effect : shatterEffects) {
            effect.draw(window);
        }

        if (fontLoaded) {
            hpText.setString("Red HP: " + std::to_string(red.hp) + "   Blue HP: " + std::to_string(blue.hp));
            window.draw(hpText);
        }

        if (red.hp <= 0 || blue.hp <= 0) {
            std::string winner = (red.hp <= 0 ? "Blue" : "Red");
            winText.setString(winner + " wins! Press ESC");
            winText.setPosition(WINDOW_WIDTH/2 - 150, WINDOW_HEIGHT/2 - 50);
            window.draw(winText);
            if (sf::Keyboard::isKeyPressed(sf::Keyboard::Escape))
                window.close();
        }

        window.display();
    }
    return 0;
}
